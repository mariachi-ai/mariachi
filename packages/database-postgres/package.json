    "@mariachi/core": "workspace:*",
    "@mariachi/database": "workspace:*",
    "@mariachi/notifications": "workspace:*",
    "@mariachi/webhooks": "workspace:*",
    "drizzle-orm": "^0.38",
    "postgres": "^3.4"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "tsup": "^8",
    "drizzle-kit": "^0.30"
  }
